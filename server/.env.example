# Copy this file to ".env" and fill in real values before running the server.
# Never commit your actual .env file — it holds secrets.

# Port the server listens on.
PORT=8000

# Secret used to sign login tokens (JWT). Use a long random string in
# production. You can generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Your Supabase Postgres connection string.
# Get it from: Supabase dashboard -> Project Settings -> Database -> Connection string
#   - Use the "Session pooler" or "Transaction pooler" string if you're
#     deploying to a serverless/edge host; use the direct connection string
#     for a normal always-on server (Railway, Render, a VPS, or localhost).
#   - Fill in the password you set when the project was created (this is
#     NOT the anon/publishable key from supabase.js — that key is for
#     client-side REST calls and can't be used for a raw SQL connection).
# Example shape:
#   postgresql://postgres:[YOUR-PASSWORD]@db.xbujspfrjfxonimkngmv.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
